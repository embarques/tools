# MongoDB
# ============================================================
MONGO_URI="mongodb://mongo1:27017,mongo2:27017,mongo3:27017/?replicaSet=rs0&connectTimeoutMS=10000&authSource=admin&authMechanism=SCRAM-SHA-256"
MONGO_DB=clientdb
MONGO_COLLECTION=invoices
MONGO_USERNAME=xxx
MONGO_PASSWORD=xxx

# ============================================================
# Transfer
# ============================================================
UPsert_KEY=oldID
