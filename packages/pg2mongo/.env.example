# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_SERVER=embserver.embarques.net
POSTGRES_PORT=5432
POSTGRES_DB=mydb
POSTGRES_USERNAME=myuser
POSTGRES_PASSWORD=mypass
PG_SCHEMA=public
PG_TABLE=invoices

