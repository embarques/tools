# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_SERVER=embserver.embarques.net
POSTGRES_PORT=5432
POSTGRES_DB=mydb
POSTGRES_USERNAME=your_pg_user
POSTGRES_PASSWORD=your_pg_password
PG_SCHEMA=public
PG_TABLE=invoices

# ============================================================
# MongoDB
# ============================================================
#
# Option A — Replica set (default below): URI without credentials;
#             set MONGO_USERNAME and MONGO_PASSWORD separately.
#
# Option B — MongoDB Atlas: put the full URI with embedded credentials
#             in MONGO_URI and leave MONGO_USERNAME / MONGO_PASSWORD empty.
#
#   MONGO_URI=mongodb+srv://your_user:your_password@cluster0.example.mongodb.net/?retryWrites=true&w=majority&authSource=admin
#   MONGO_DB=clientdb
#   MONGO_USERNAME=
#   MONGO_PASSWORD=
#
MONGO_URI="mongodb://mongo1:27017,mongo2:27017,mongo3:27017/?replicaSet=rs0&connectTimeoutMS=10000&authSource=admin&authMechanism=SCRAM-SHA-256"
MONGO_DB=clientdb
MONGO_COLLECTION=invoices
MONGO_USERNAME=your_mongo_user
MONGO_PASSWORD=your_mongo_password

# ============================================================
# Transfer
# ============================================================
UPsert_KEY=oldID
